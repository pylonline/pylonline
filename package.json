{
  "name": "@pylonline/workspace",
  "private": true,
  "description": "Workspace orchestration repo for the Pylonline repos",
  "scripts": {
    "submodules:init": "git submodule update --init --recursive",
    "submodules:checkout-main": "git submodule foreach --recursive 'git switch main'",
    "submodules:update": "git submodule update --remote --recursive",
    "submodules:status": "git submodule status --recursive",
    "curstats": "node scripts/curstats.cjs",
    "install:workspace": "pnpm install",
    "lint:workspace-root": "node core-lint/bin/core-lint.cjs lint",
    "stylelint:workspace-root": "node core-lint/bin/core-lint.cjs stylelint",
    "format:check:workspace-root": "node core-lint/bin/core-lint.cjs format",
    "format:write:workspace-root": "node core-lint/bin/core-lint.cjs format --write",
    "check:workspace-root": "node core-lint/bin/core-lint.cjs check",
    "check": "npm run check:workspace-root && pnpm -r --if-present run check",
    "test": "pnpm -r --if-present run test",
    "coverage": "pnpm -r --if-present run coverage",
    "lint": "npm run lint:workspace-root && pnpm -r --if-present run lint",
    "stylelint": "npm run stylelint:workspace-root && pnpm -r --if-present run stylelint",
    "format:check": "npm run format:check:workspace-root && pnpm -r --if-present run format:check",
    "portal:ui:sync": "pnpm --filter @pylonline/portal --fail-if-no-match run ui:sync",
    "portal:ui:check": "pnpm --filter @pylonline/portal --fail-if-no-match run ui:check",
    "pylon:ui:sync": "pnpm --filter @pylonline/pylon --fail-if-no-match run ui:sync",
    "pylon:ui:check": "pnpm --filter @pylonline/pylon --fail-if-no-match run ui:check"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "tsx": "^4.21.0"
  }
}
